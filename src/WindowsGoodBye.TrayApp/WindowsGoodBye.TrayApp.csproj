  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="QRCoder" Version="1.6.*" />
    <ProjectReference Include="..\WindowsGoodBye.Core\WindowsGoodBye.Core.csproj" />
  </ItemGroup>
</Project>
